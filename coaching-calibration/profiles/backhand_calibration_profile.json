{
  "profile_id": "backhand_phase_calibration",
  "profile_version": "1.0.0",
  "profile_name": "Backhand Phase Calibration",
  "description": "Calibration workflow for backhand groundstroke phase labelling, phase-level quality assessment, overall shot assessment, and structured coaching observations.",
  "shot_type": "Backhand",
  "ontology_id": "padel_partner_iq_coaching_ontology",
  "ontology_version": "1.0.0",
  "phases": [
    {
      "id": "ready_position",
      "shortcut": "1",
      "observations": [
        "stance_width",
        "knee_bend",
        "body_balance"
      ]
    },
    {
      "id": "max_take_back",
      "shortcut": "2",
      "observations": [
        "shoulder_turn",
        "hip_rotation",
        "shoulder_hip_separation",
        "hitting_arm_structure",
        "non_hitting_arm_support",
        "elbow_position",
        "knee_bend",
        "body_balance",
        "shoulder_vertical_alignment",
        "stance_width"
      ]
    },
    {
      "id": "contact_point",
      "shortcut": "3",
      "observations": [
        "shoulder_turn",
        "hip_rotation",
        "shoulder_hip_separation",
        "hitting_arm_structure",
        "non_hitting_arm_support",
        "elbow_position",
        "knee_bend",
        "contact_height",
        "contact_distance",
        "body_balance",
        "shoulder_vertical_alignment",
        "stance_width",
        "weight_transfer"
      ]
    },
    {
      "id": "max_follow_through",
      "shortcut": "4",
      "observations": [
        "shoulder_turn",
        "hip_rotation",
        "hitting_arm_structure",
        "non_hitting_arm_support",
        "elbow_position",
        "knee_bend",
        "body_balance",
        "stance_width",
        "weight_transfer",
        "follow_through_shape"
      ]
    },
    {
      "id": "recovery_position",
      "shortcut": "5",
      "observations": [
        "knee_bend",
        "body_balance",
        "stance_width"
      ]
    }
  ],
  "ratings": [
    "not_assessed",
    "too_little",
    "good",
    "excellent",
    "too_much",
    "unclear"
  ],
  "quality_ratings": [
    "not_assessed",
    "excellent",
    "good",
    "needs_work",
    "red_flag",
    "unclear"
  ],
  "capture": {
    "requires_overall_quality": false,
    "requires_phase_quality": false,
    "requires_all_phases_for_export": true,
    "allow_duplicate_frame_labels_with_warning": true
  },
  "export": {
    "include_profile_version": true,
    "include_ontology_version": true,
    "include_overall_quality": true,
    "include_overall_notes": true,
    "include_phase_quality": true,
    "include_phase_notes": true,
    "include_structured_observations": true
  }
}
